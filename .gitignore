# ------------------------------
# App (frontend)
# ------------------------------
/app/logs
/app/*.log
/app/npm-debug.log*
/app/yarn-debug.log*
/app/yarn-error.log*
/app/pnpm-debug.log*
/app/lerna-debug.log*

/app/node_modules
/app/dist
/app/dist-ssr
/app/*.local
/app/.env
/app/.env.*
!/app/.env.example

# ------------------------------
# API (backend)
# ------------------------------
/api/dist
/api/node_modules
/api/build
/api/*.tsbuildinfo

/app/*.tsbuildinfo

/api/logs
/api/*.log
/api/npm-debug.log*
/api/pnpm-debug.log*
/api/yarn-debug.log*
/api/yarn-error.log*
/api/lerna-debug.log*

/api/coverage
/api/.nyc_output

/api/.env
/api/.env.development.local
/api/.env.test.local
/api/.env.production.local
/api/.env.local
!/api/.env.example

